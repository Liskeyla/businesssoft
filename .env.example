# =============================================================
# Business Soft S.A. - Variables de entorno
# Copia este archivo como ".env.local" y completa los valores.
# =============================================================

# EmailJS (https://www.emailjs.com/) - Formulario de contacto
# Si no se configuran, el formulario funcionará en modo demostración.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# URL pública del sitio (usada para SEO, sitemap y Open Graph)
NEXT_PUBLIC_SITE_URL=https://businesssoft.vercel.app
